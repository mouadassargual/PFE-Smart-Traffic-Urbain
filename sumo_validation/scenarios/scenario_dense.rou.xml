<?xml version="1.0" encoding="UTF-8"?>
<!--
    Scénario Dense Nord : heure de pointe
    25 véhicules Nord, arrivée en rafale (1 toutes les 3s)
    Attendu MDP : Phase NS / 45s → AWT réduit significativement
-->
<routes>
    <vType id="car"   length="4.5" maxSpeed="13.89" accel="2.6" decel="4.5" minGap="2.5"/>
    <vType id="bus"   length="12.0" maxSpeed="11.11" accel="1.2" decel="3.0" minGap="3.0"/>
